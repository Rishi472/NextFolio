{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "VITE_API_URL": "@api_url",
    "VITE_GOOGLE_CLIENT_ID": "@google_client_id",
    "VITE_ENABLE_GOOGLE_LOGIN": "@enable_google_login"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
